<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PlanMe - Classroom Management</title>
    
    <style>
        :root { --primary: #4a90e2; --secondary: #27ae60; --danger: #e74c3c; --bg: #f5f7fa; }
        body { font-family: 'Tahoma', sans-serif; background-color: var(--bg); margin: 0; padding: 20px; display: flex; justify-content: center; }
        .container { width: 100%; max-width: 600px; background: white; padding: 25px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        h1 { text-align: center; color: var(--primary); margin-bottom: 25px; }
        
        .input-box { display: flex; flex-direction: column; gap: 10px; margin-bottom: 25px; padding: 15px; border: 1px solid #eee; border-radius: 8px; }
        input { padding: 12px; border: 1px solid #ddd; border-radius: 6px; font-size: 16px; }
        button { padding: 12px; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; transition: 0.3s; }
        
        #btnSave { background-color: var(--secondary); color: white; }
        #btnSave:hover { background-color: #219150; }
        
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th { background-color: #f8f9fa; color: #555; padding: 12px; border-bottom: 2px solid #eee; text-align: left; }
        td { padding: 12px; border-bottom: 1px solid #eee; }
        
        .btn-del { background-color: var(--danger); color: white; padding: 6px 12px; font-size: 13px; }
        .btn-del:hover { opacity: 0.8; }
        .loading { text-align: center; color: #888; font-style: italic; }
    </style>
</head>
<body>

<div class="container">
    <h1>PlanMe Management</h1>

    <div class="input-box">
        <input type="text" id="studentId" placeholder="เลขประจำตัวนักเรียน">
        <input type="text" id="studentName" placeholder="ชื่อ-นามสกุล">
        <button id="btnSave">บันทึกลงระบบ PlanMe</button>
    </div>

    <table>
        <thead>
            <tr>
                <th>รหัส</th>
                <th>ชื่อ-นามสกุล</th>
                <th>จัดการ</th>
            </tr>
        </thead>
        <tbody id="studentList">
            <tr><td colspan="3" class="loading">กำลังโหลดข้อมูล...</td></tr>
        </tbody>
    </table>
</div>

<script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
    import { getFirestore, collection, addDoc, onSnapshot, deleteDoc, doc, query, orderBy }
