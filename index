<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PlanMe - Classroom Management</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <div class="container">
        <h1>PlanMe Management</h1>
        
        <div class="card">
            <h3>เพิ่มข้อมูลนักเรียน</h3>
            <div class="input-group">
                <input type="text" id="studentName" placeholder="ชื่อ-นามสกุล">
                <input type="text" id="studentId" placeholder="เลขประจำตัว">
                <button id="btnSave">บันทึกข้อมูล</button>
            </div>
        </div>

        <div class="card">
            <h3>รายชื่อนักเรียน</h3>
            <table>
                <thead>
                    <tr>
                        <th>เลขประจำตัว</th>
                        <th>ชื่อ-นามสกุล</th>
                        <th>จัดการ</th>
                    </tr>
                </thead>
                <tbody id="studentList">
                    </tbody>
            </table>
        </div>
    </div>

    <script type="module" src="script.js"></script>
</body>
</html>
